# vendored site assets are committed on purpose; keep them out of the generic
# build/ and dist/ ignores above (KaTeX ships in a canonical dist/ layout).
!docs/assets/vendor/**

# generated planning/spec docs + visual-companion scratch
docs/superpowers/
.superpowers/

# latex build artifacts
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz

# run outputs (large, regenerable, per-execution)
runs/

# shengbte run artifacts inside experiments/ — regenerable from convert.py + ShengBTE
experiments/silicon_shengbte/BTE.*
experiments/silicon_shengbte/T*K/
experiments/silicon_shengbte/FORCE_CONSTANTS_*
experiments/silicon_shengbte/kaldo_fc3_dump/
experiments/shengbte_inas_smoke/

# experiment scratch (generated displaced supercells, force files, etc.)
experiments/*/scratch/
experiments/*/__pycache__/

# editors / OS
.vscode/
.idea/
.DS_Store
*.swp
*~
log.lammps
experiments/*/log.lammps
AtomisticSkills/

