   },
   {
    "quantity": "chemical_potential",
    "units": "eV"
   }
  ],
  "operation": {
   "kind": "mlip_relax_defect",
   "closed_form": "E_f = E_defect - (n_defect/n_bulk)*E_bulk + sum_i(delta_n_i * mu_i)"
  },
  "codes": [
   "MACE-MP",
   "CHGNet",
   "pymatgen-analysis-defects",
   "ASE"
  ],
  "example_instances": [
