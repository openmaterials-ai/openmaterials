    "ref": "examples/MgO_vacancy/defect_energies.json"
   },
   {
    "material": "MgO Mg-vacancy",
    "value": 7.3849191666641545,
    "units": "eV",
    "conditions": "neutral charge, metal-rich limit, MACE-MH-1 matpes_r2scan, 2x2x2 supercell",
    "ref": "examples/MgO_vacancy/defect_energies.json"
   }
  ]
 },
