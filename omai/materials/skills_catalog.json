  "name": "mat-defect-energy",
  "produces": [
   {
    "quantity": "defect_formation_energy",
    "symbol": "E_f",
    "units": "eV",
    "gauge": "observable",
    "indices": [
     "defect_type"
    ]
   }
  ],
  "consumes": [
