&CONTROL
  calculation = "scf"
  prefix      = "si"
  outdir      = "./out"
  pseudo_dir  = "./"
  verbosity   = "high"
  tprnfor     = .true.
  tstress     = .true.
/
&SYSTEM
  ibrav       = 2
  celldm(1)   = 10.2625
  nat         = 2
  ntyp        = 1
  ecutwfc     = 50.0
  occupations = "fixed"
/
&ELECTRONS
  conv_thr    = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
Si  28.0855  Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
Si  0.00  0.00  0.00
Si  0.25  0.25  0.25
K_POINTS automatic
8 8 8 1 1 1
