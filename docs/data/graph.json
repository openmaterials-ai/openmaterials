{"nodes": [{"id": "Potential", "type": "observable", "layer": 0, "kind": "symbolic", "symbol": "V", "formula": "V{\\left(\\{u\\} \\right)} = V_{\\mathrm{provided}}", "tier": "Sources"}, {"id": "Temperature", "type": "observable", "layer": 0, "kind": "symbolic", "symbol": "T", "formula": "T = T_{\\mathrm{provided}}", "tier": "Sources"}, {"id": "ForceConstants[order=2]", "type": "observable", "layer": 1, "kind": "symbolic", "symbol": "\\Phi^{(2)}", "formula": "{\\Phi^{(2)}}_{i,j,\\mathbf{R}} = \\frac{d^{2}}{d u_{j(R)}d u_{i(0)}} V{\\left(\\{u\\} \\right)}", "tier": "Sources"}, {"id": "ForceConstants[order=3]", "type": "observable", "layer": 1, "kind": "symbolic", "symbol": "\\Phi^{(3)}", "formula": "{\\Phi^{(3)}}_{i,j,k,\\mathbf{R},\\mathbf{R'}} = \\frac{d^{3}}{d u_{k(R')}d u_{j(R)}d u_{i(0)}} V{\\left(\\{u\\} \\right)}", "tier": "Sources"}, {"id": "BornCharges", "type": "observable", "layer": 0, "kind": "symbolic", "symbol": "Z^{*}", "formula": "{Z^{*}}_{i,\\gamma,\\alpha} = Z^*_{provided}", "tier": "Sources"}, {"id": "DielectricTensor", "type": "observable", "layer": 0, "kind": "symbolic", "symbol": "\\varepsilon_{\\infty}", "formula": "{\\varepsilon_{\\infty}}_{\\gamma,\\delta} = \\varepsilon_{\\infty,provided}", "tier": "Sources"}, {"id": "BareDynamicalMatrix", "type": "observable", "layer": 2, "kind": "symbolic", "symbol": "D^{0}", "formula": "{D^{bare}}_{i,j,\\mathbf{q}} = \\frac{\\sum_{\\mathbf{R}=-\\infty}^{\\infty} e^{i \\mathbf{R} \\mathbf{q}} {\\Phi^{(2)}}_{i,j,\\mathbf{R}}}{\\sqrt{{M}_{i} {M}_{j}}}", "tier": "Harmonic"}, {"id": "DynamicalMatrix", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "D", "formula": "{D}_{i,j,\\mathbf{q}} = {D^{bare}}_{i,j,\\mathbf{q}}", "tier": "Harmonic"}, {"id": "Frequency", "type": "observable", "layer": 4, "kind": "symbolic", "symbol": "\\omega", "formula": "\\sum_{j=1}^{3 N} {D}_{i,j,\\mathbf{q}} {e}_{j,\\mathbf{q},\\nu} = {\\omega}_{\\mathbf{q},\\nu}^{2} {e}_{i,\\mathbf{q},\\nu}", "tier": "Harmonic"}, {"id": "Eigenvectors", "type": "hidden", "layer": 4, "kind": "symbolic", "symbol": "e", "formula": "\\sum_{j=1}^{3 N} {D}_{i,j,\\mathbf{q}} {e}_{j,\\mathbf{q},\\nu} = {\\omega}_{\\mathbf{q},\\nu}^{2} {e}_{i,\\mathbf{q},\\nu}", "tier": "Harmonic"}, {"id": "GroupVelocity", "type": "hidden", "layer": 5, "kind": "symbolic", "symbol": "v", "formula": "{v}_{\\alpha,\\mathbf{q},\\nu} = \\frac{\\sum_{\\substack{1 \\leq j \\leq 3 N\\\\1 \\leq i \\leq 3 N}} \\overline{{e}_{i,\\mathbf{q},\\nu}} {\\partial D/\\partial q}_{i,j,\\alpha,\\mathbf{q}} {e}_{j,\\mathbf{q},\\nu}}{2 {\\omega}_{\\mathbf{q},\\nu}}", "tier": "Harmonic"}, {"id": "HeatCapacity", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "c", "formula": "{c}_{\\mathbf{q},\\nu} = \\frac{\\bar{\\h}^{2} {\\omega}_{\\mathbf{q},\\nu}^{2}}{4 T^{2} k_{B} \\sinh^{2}{\\left(\\frac{\\bar{\\h} {\\omega}_{\\mathbf{q},\\nu}}{2 T k_{B}} \\right)}}", "tier": "Thermodynamics"}, {"id": "VolumetricHeatCapacity", "type": "observable", "layer": 6, "kind": "symbolic", "symbol": "C_{V}", "formula": "C_V^{vol} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {c}_{\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Thermodynamics"}, {"id": "MolarHeatCapacity", "type": "observable", "layer": 6, "kind": "symbolic", "symbol": "C_{\\mathrm{m}}", "formula": "C_V^{mol} = \\frac{N_{A} \\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {c}_{\\mathbf{q},\\nu}}{N_{q}}", "tier": "Thermodynamics"}, {"id": "HelmholtzFreeEnergy", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "F", "formula": "{f}_{\\mathbf{q},\\nu} = T k_{B} \\log{\\left(1 - e^{- \\frac{\\bar{\\h} {\\omega}_{\\mathbf{q},\\nu}}{T k_{B}}} \\right)} + \\frac{\\bar{\\h} {\\omega}_{\\mathbf{q},\\nu}}{2}", "tier": "Thermodynamics"}, {"id": "Entropy", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "S", "formula": "{s}_{\\mathbf{q},\\nu} = - k_{B} \\log{\\left(1 - e^{- \\frac{\\bar{\\h} {\\omega}_{\\mathbf{q},\\nu}}{T k_{B}}} \\right)} + \\frac{\\bar{\\h} n_{BE}{\\left(\\frac{{\\omega}_{\\mathbf{q},\\nu}}{T} \\right)} {\\omega}_{\\mathbf{q},\\nu}}{T}", "tier": "Thermodynamics"}, {"id": "InternalEnergy", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "E", "formula": "{e}_{\\mathbf{q},\\nu} = \\bar{\\h} \\left(n_{BE}{\\left(\\frac{{\\omega}_{\\mathbf{q},\\nu}}{T} \\right)} + \\frac{1}{2}\\right) {\\omega}_{\\mathbf{q},\\nu}", "tier": "Thermodynamics"}, {"id": "MolarHelmholtzFreeEnergy", "type": "observable", "layer": 6, "kind": "symbolic", "symbol": "F_{\\mathrm{m}}", "formula": "F_{mol} = \\frac{N_{A} \\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {f}_{\\mathbf{q},\\nu}}{N_{q}}", "tier": "Thermodynamics"}, {"id": "MolarEntropy", "type": "observable", "layer": 6, "kind": "symbolic", "symbol": "S_{\\mathrm{m}}", "formula": "S_{mol} = \\frac{N_{A} \\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {s}_{\\mathbf{q},\\nu}}{N_{q}}", "tier": "Thermodynamics"}, {"id": "MolarInternalEnergy", "type": "observable", "layer": 6, "kind": "symbolic", "symbol": "E_{\\mathrm{m}}", "formula": "E_{mol} = \\frac{N_{A} \\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {e}_{\\mathbf{q},\\nu}}{N_{q}}", "tier": "Thermodynamics"}, {"id": "Linewidth[channel=anharmonic_3ph]", "type": "hidden", "layer": 5, "kind": "symbolic", "symbol": "\\Gamma_{\\mathrm{3ph}}", "formula": "{\\Gamma}_{\\mathbf{q},\\nu} = \\frac{\\pi \\sum_{\\substack{1 \\leq \\mathbf{q'} \\leq N_{q}\\\\1 \\leq \\nu' \\leq 3 N\\\\1 \\leq \\nu'' \\leq 3 N}} \\left(\\left(- 2 n_{BE}{\\left(\\frac{{\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''}}{T} \\right)} + 2 n_{BE}{\\left(\\frac{{\\omega}_{\\mathbf{q'},\\nu'}}{T} \\right)}\\right) \\delta{\\left(- {\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''} + {\\omega}_{\\mathbf{q'},\\nu'} + {\\omega}_{\\mathbf{q},\\nu} \\right)} + \\left(n_{BE}{\\left(\\frac{{\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''}}{T} \\right)} + n_{BE}{\\left(\\frac{{\\omega}_{\\mathbf{q'},\\nu'}}{T} \\right)} + 1\\right) \\delta{\\left(- {\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''} - {\\omega}_{\\mathbf{q'},\\nu'} + {\\omega}_{\\mathbf{q},\\nu} \\right)}\\right) \\operatorname{|V}^{2}_{3|}{\\left(\\mathbf{q},\\nu,\\mathbf{q'},\\nu',- \\mathbf{q'} + \\mathbf{q},\\nu'' \\right)}}{N \\bar{\\h}^{2}}", "tier": "Scattering"}, {"id": "Linewidth[channel=isotope]", "type": "hidden", "layer": 5, "kind": "symbolic", "symbol": "\\Gamma_{\\mathrm{iso}}", "formula": "{\\Gamma^{iso}}_{\\mathbf{q},\\nu} = \\frac{\\pi {\\omega}_{\\mathbf{q},\\nu}^{2} \\sum_{\\substack{1 \\leq \\mathbf{q'} \\leq N_{q}\\\\1 \\leq \\nu' \\leq 3 N}} \\delta{\\left(- {\\omega}_{\\mathbf{q'},\\nu'} + {\\omega}_{\\mathbf{q},\\nu} \\right)} \\left(\\left|{\\sum_{i=1}^{N} \\overline{{e}_{i,\\mathbf{q},\\nu}} {e}_{i,\\mathbf{q'},\\nu'}}\\right|^{2}\\right) {g}_{i}}{2}", "tier": "Scattering"}, {"id": "Linewidth[channel=boundary]", "type": "hidden", "layer": 6, "kind": "symbolic", "symbol": "\\Gamma_{\\mathrm{bnd}}", "formula": "{\\Gamma^{bnd}}_{\\mathbf{q},\\nu} = \\frac{\\sqrt{\\sum_{\\alpha=1}^{3} {v}_{\\alpha,\\mathbf{q},\\nu}^{2}}}{L}", "tier": "Scattering"}, {"id": "Linewidth[channel=total]", "type": "hidden", "layer": 7, "kind": "symbolic", "symbol": "\\Gamma", "formula": "{\\Gamma^{tot}}_{\\mathbf{q},\\nu} = {\\Gamma^{anh}}_{\\mathbf{q},\\nu} + {\\Gamma^{bnd}}_{\\mathbf{q},\\nu} + {\\Gamma^{iso}}_{\\mathbf{q},\\nu}", "tier": "Scattering"}, {"id": "IsotopeAbundances", "type": "observable", "layer": 0, "kind": "symbolic", "symbol": "g_{\\mathrm{iso}}", "formula": "{g}_{i} = g_{provided}", "tier": "Sources"}, {"id": "PhononDOS", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "g(\\omega)", "formula": "g = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} \\delta{\\left(\\omega - {\\omega}_{\\mathbf{q},\\nu} \\right)}}{N_{q}}", "tier": "Harmonic"}, {"id": "Gruneisen", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "\\gamma", "formula": "{\\gamma_{G}}_{\\mathbf{q},\\nu} = - \\frac{\\sum_{\\substack{1 \\leq i \\leq 3 N\\\\1 \\leq j \\leq 3 N}} {\\Phi^{(3)}}_{i,j,k,\\mathbf{R},\\mathbf{R'}}}{6 {\\omega}_{\\mathbf{q},\\nu}^{2}}", "tier": "Scattering"}, {"id": "PhaseSpace3Phonon", "type": "observable", "layer": 5, "kind": "symbolic", "symbol": "P_{3}", "formula": "{P_{3}}_{\\mathbf{q},\\nu} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q'} \\leq N_{q}\\\\1 \\leq \\nu' \\leq 3 N\\\\1 \\leq \\nu'' \\leq 3 N}} \\left(\\delta{\\left(- {\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''} - {\\omega}_{\\mathbf{q'},\\nu'} + {\\omega}_{\\mathbf{q},\\nu} \\right)} + 2 \\delta{\\left(- {\\omega}_{- \\mathbf{q'} + \\mathbf{q},\\nu''} + {\\omega}_{\\mathbf{q'},\\nu'} + {\\omega}_{\\mathbf{q},\\nu} \\right)}\\right)}{N_{q}}", "tier": "Scattering"}, {"id": "MeanFreeDisplacement[bte_solver=rta]", "type": "hidden", "layer": 8, "kind": "symbolic", "symbol": "\\lambda_{\\mathrm{rta}}", "formula": "{F}_{\\alpha,\\mathbf{q},\\nu} = \\frac{{v}_{\\alpha,\\mathbf{q},\\nu}}{2 {\\Gamma}_{\\mathbf{q},\\nu}}", "tier": "Transport"}, {"id": "MeanFreeDisplacement[bte_solver=direct_inverse]", "type": "observable", "layer": 8, "kind": "symbolic", "symbol": "\\lambda_{\\mathrm{dinv}}", "formula": "\\sum_{\\substack{1 \\leq \\mathbf{q'} \\leq N_{q}\\\\1 \\leq \\nu' \\leq 3 N}} {F}_{\\alpha,\\mathbf{q'},\\nu'} {\\mathcal{M}}_{\\mathbf{q},\\nu,\\mathbf{q'},\\nu'} = {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}", "tier": "Transport"}, {"id": "ThermalConductivity[bte_solver=rta]", "type": "hidden", "layer": 9, "kind": "symbolic", "symbol": "\\kappa^{\\mathrm{rta}}", "formula": "{\\kappa}_{\\alpha,\\beta} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {F}_{\\beta,\\mathbf{q},\\nu} {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "ThermalConductivity[bte_solver=direct_inverse]", "type": "observable", "layer": 9, "kind": "symbolic", "symbol": "\\kappa^{\\mathrm{dinv}}", "formula": "{\\kappa}_{\\alpha,\\beta} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {F}_{\\beta,\\mathbf{q},\\nu} {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "ThermalConductivity[transport_model=wigner_populations]", "type": "observable", "layer": 9, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{pop}}", "formula": "{\\kappa^{W,pop}}_{\\alpha,\\beta} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} {F}_{\\beta,\\mathbf{q},\\nu} {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "ThermalConductivity[transport_model=wigner_coherences]", "type": "observable", "layer": 8, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{coh}}", "formula": "{\\kappa^{W,coh}}_{\\alpha,\\beta} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N\\\\1 \\leq \\nu' \\leq 3 N}} \\frac{\\left({\\Gamma^{anh}}_{\\mathbf{q},\\nu'} + {\\Gamma^{anh}}_{\\mathbf{q},\\nu}\\right) \\left({\\omega}_{\\mathbf{q},\\nu'} + {\\omega}_{\\mathbf{q},\\nu}\\right) \\left(\\frac{{c}_{\\mathbf{q},\\nu'}}{2} + \\frac{{c}_{\\mathbf{q},\\nu}}{2}\\right) {v}_{\\alpha,\\mathbf{q},\\nu} {v}_{\\beta,\\mathbf{q},\\nu'}}{2 \\left(\\left({\\Gamma^{anh}}_{\\mathbf{q},\\nu'} + {\\Gamma^{anh}}_{\\mathbf{q},\\nu}\\right)^{2} + \\left(- {\\omega}_{\\mathbf{q},\\nu'} + {\\omega}_{\\mathbf{q},\\nu}\\right)^{2}\\right)}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "ThermalConductivity[transport_model=wigner]", "type": "observable", "layer": 10, "kind": "symbolic", "symbol": "\\kappa", "formula": "{\\kappa^{W}}_{\\alpha,\\beta} = {\\kappa^{W,coh}}_{\\alpha,\\beta} + {\\kappa^{W,pop}}_{\\alpha,\\beta}", "tier": "Transport"}, {"id": "ThermalConductivity[transport_model=qhgk]", "type": "hidden", "layer": 8, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{qhgk}}", "formula": "{\\kappa^{QHGK}}_{\\alpha,\\beta} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N\\\\1 \\leq \\nu' \\leq 3 N}} \\frac{\\left({\\Gamma^{anh}}_{\\mathbf{q},\\nu'} + {\\Gamma^{anh}}_{\\mathbf{q},\\nu}\\right) {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu} {v}_{\\beta,\\mathbf{q},\\nu'}}{\\left({\\Gamma^{anh}}_{\\mathbf{q},\\nu'} + {\\Gamma^{anh}}_{\\mathbf{q},\\nu}\\right)^{2} + \\left(- {\\omega}_{\\mathbf{q},\\nu'} + {\\omega}_{\\mathbf{q},\\nu}\\right)^{2}}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "CumulativeKappa[wrt=omega]", "type": "observable", "layer": 9, "kind": "symbolic", "symbol": "\\kappa^{\\mathrm{cum}}_{\\omega}", "formula": "{\\kappa^{cum}_\\omega}_{\\alpha,\\beta,\\omega_{c}} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} \\theta{\\left(\\omega_{c} - {\\omega}_{\\mathbf{q},\\nu} \\right)} {F}_{\\beta,\\mathbf{q},\\nu} {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "CumulativeKappa[wrt=mfp]", "type": "observable", "layer": 9, "kind": "symbolic", "symbol": "\\kappa^{\\mathrm{cum}}_{\\lambda}", "formula": "{\\kappa^{cum}_\\Lambda}_{\\alpha,\\beta,\\Lambda_{c}} = \\frac{\\sum_{\\substack{1 \\leq \\mathbf{q} \\leq N_{q}\\\\1 \\leq \\nu \\leq 3 N}} \\left(\\theta{\\left(\\Lambda_{c} - \\sqrt{\\sum_{\\alpha=1}^{3} {F}_{\\alpha,\\mathbf{q},\\nu}^{2}} \\right)}\\right) {F}_{\\beta,\\mathbf{q},\\nu} {c}_{\\mathbf{q},\\nu} {v}_{\\alpha,\\mathbf{q},\\nu}}{N_{q} V_{cell}}", "tier": "Transport"}, {"id": "Trajectory", "type": "hidden", "layer": 1, "kind": "symbolic", "symbol": "\\mathbf{r}(t)", "formula": "{r}_{i,\\alpha,t + 1} = \\frac{\\Delta t^{2} {F^{md}}_{i,\\alpha,t}}{2} + \\Delta t {v}_{i,\\alpha,t} + {r}_{i,\\alpha,t}", "tier": "Molecular dynamics"}, {"id": "HeatCurrent", "type": "hidden", "layer": 2, "kind": "symbolic", "symbol": "\\mathbf{J}", "formula": "{J}_{\\alpha,t} = \\frac{\\sum_{i=1}^{N_{atoms}} {E}_{i,t} {v}_{i,\\alpha,t} + \\frac{\\sum_{i=1}^{N_{atoms}} {F^{md}}_{i,\\alpha,t} {r}_{i,\\alpha,t} {v}_{i,\\alpha,t}}{2}}{V_{cell}}", "tier": "Molecular dynamics"}, {"id": "HeatCurrentACF", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "\\langle JJ\\rangle", "formula": "{Jcorr}_{\\alpha,\\beta,\\tau} = \\frac{\\sum_{t=1}^{n_{lag}} {J}_{\\alpha,t} {J}_{\\beta,\\tau + t}}{n_{lag}}", "tier": "Molecular dynamics"}, {"id": "VelocityAutocorrelation", "type": "observable", "layer": 2, "kind": "symbolic", "symbol": "\\langle v(0)v(t)\\rangle", "formula": "{Cv}_{\\tau} = \\frac{\\sum_{\\substack{1 \\leq \\alpha \\leq 3\\\\1 \\leq i \\leq N_{atoms}\\\\1 \\leq t \\leq n_{lag}}} {v}_{i,\\alpha,\\tau + t} {v}_{i,\\alpha,t}}{N_{atoms} n_{lag}}", "tier": "Molecular dynamics"}, {"id": "MeanSquaredDisplacement", "type": "observable", "layer": 2, "kind": "symbolic", "symbol": "\\langle u^{2}\\rangle", "formula": "{M}_{\\tau} = \\frac{\\sum_{\\substack{1 \\leq \\alpha \\leq 3\\\\1 \\leq i \\leq N_{atoms}\\\\1 \\leq t \\leq n_{lag}}} \\left({r}_{i,\\alpha,\\tau + t} - {r}_{i,\\alpha,t}\\right)^{2}}{N_{atoms} n_{lag}}", "tier": "Molecular dynamics"}, {"id": "ThermalConductivity[transport_model=green_kubo]", "type": "observable", "layer": 4, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{gk}}", "formula": "{\\kappa^{MD}}_{\\alpha,\\beta} = \\frac{V_{cell} \\int\\limits_{0}^{\\tau_{max}} {Jcorr}_{\\alpha,\\beta,\\tau}\\, d\\tau}{T^{2} k_{B}}", "tier": "Molecular dynamics"}, {"id": "ThermalConductivity[transport_model=nemd]", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{nemd}}", "formula": "{\\kappa^{MD}}_{\\alpha,\\beta} = - \\frac{{J}_{\\alpha,t}}{{\\nabla T}_{\\beta}}", "tier": "Molecular dynamics"}, {"id": "ThermalConductivity[transport_model=hnemd]", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "\\kappa_{\\mathrm{hnemd}}", "formula": "{\\kappa^{MD}}_{\\alpha,\\beta} = \\frac{{J}_{\\alpha,t}}{T V_{cell} {F_{e}}_{\\beta}}", "tier": "Molecular dynamics"}, {"id": "Diffusivity", "type": "observable", "layer": 3, "kind": "symbolic", "symbol": "D", "formula": "D = \\frac{\\mathrm{slope}_{MSD}}{2 d}", "tier": "Diffusion"}, {"id": "ActivationEnergy", "type": "observable", "layer": 4, "kind": "symbolic", "symbol": "E_a", "formula": "D{\\left(T \\right)} = D_{0} e^{- \\frac{E_{a}}{T k_{B}}}", "tier": "Diffusion"}, {"id": "CellVolume", "type": "parameter", "layer": 0, "kind": "symbolic", "symbol": "V_{\\mathrm{cell}}", "formula": null, "tier": "Sources"}, {"id": "AtomicMass", "type": "parameter", "layer": 0, "kind": "symbolic", "symbol": "M", "formula": null, "tier": "Sources"}, {"id": "AtomCount", "type": "parameter", "layer": 0, "kind": "symbolic", "symbol": "N", "formula": null, "tier": "Sources"}], "links": [{"source": "Potential", "target": "ForceConstants[order=2]", "op": "compute_force_constants[order=2]"}, {"source": "Potential", "target": "ForceConstants[order=3]", "op": "compute_force_constants[order=3]"}, {"source": "ForceConstants[order=2]", "target": "BareDynamicalMatrix", "op": "compute_dynamical_matrix"}, {"source": "BareDynamicalMatrix", "target": "DynamicalMatrix", "op": "identity_dm"}, {"source": "BareDynamicalMatrix", "target": "DynamicalMatrix", "op": "apply_nac_correction"}, {"source": "BornCharges", "target": "DynamicalMatrix", "op": "apply_nac_correction"}, {"source": "DielectricTensor", "target": "DynamicalMatrix", "op": "apply_nac_correction"}, {"source": "DynamicalMatrix", "target": "Frequency", "op": "compute_dispersion"}, {"source": "DynamicalMatrix", "target": "Eigenvectors", "op": "compute_dispersion"}, {"source": "DynamicalMatrix", "target": "GroupVelocity", "op": "compute_group_velocity"}, {"source": "Frequency", "target": "GroupVelocity", "op": "compute_group_velocity"}, {"source": "Eigenvectors", "target": "GroupVelocity", "op": "compute_group_velocity"}, {"source": "Fre